{
  "name": "@webrcade/app-common",
  "version": "0.1.0",
  "description": "webrcade Application Common",
  "author": "raz0red",
  "license": "MIT",
  "repository": "https://github.com/webrcade/app-common",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.js",
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "icons": "node icons/build.js",
    "build": "npm run clean-modules && npm run icons && microbundle-crl --no-compress --format modern,cjs",
    "start": "npm run clean-modules && microbundle-crl watch --no-compress --format modern,cjs",
    "prepare": "run-s build",
    "test": "run-s test:unit test:lint test:build",
    "test:build": "run-s build",
    "test:lint": "eslint .",
    "test:unit": "cross-env CI=1 react-scripts test --env=jsdom",
    "test:watch": "react-scripts test --env=jsdom",
    "predeploy": "cd example && npm install && npm run build",
    "deploy": "gh-pages -d example/build",
    "clean-modules": "rimraf node_modules/react node_modules/react-dom",
    "poststart": "npm run clean-modules",
    "postbuild": "npm run clean-modules"
  },
  "peerDependencies": {
    "react": ">=17.0.0 <18.0.0",
    "react-dom": ">=17.0.0 <18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/plugin-proposal-unicode-property-regex": "^7.18.6",
    "babel-eslint": "^10.0.3",
    "cross-env": "^7.0.2",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.7.0",
    "eslint-config-standard": "^14.1.0",
    "eslint-config-standard-react": "^9.2.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-node": "^11.0.0",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.17.0",
    "eslint-plugin-standard": "^4.0.1",
    "microbundle-crl": "^0.13.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.0.4",
    "rimraf": "^3.0.2",
    "sass": "^1.62.0"
  },
  "optionalDependencies": {
    "react": "17.0.2",
    "react-dom": "17.0.2"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "dropbox": "^10.32.0",
    "ua-parser-js": "^1.0.2"
  }
}
